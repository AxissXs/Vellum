# Local development only.
# Do NOT commit your real .env. This file documents required variables.

# Database (local PostgreSQL)
# On Deno Deploy, DATABASE_URL is auto-injected by the Prisma Postgres integration.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vellum"

# Pusher (real-time updates) - https://pusher.com/channels
PUSHER_APP_ID="your_app_id"
PUSHER_KEY="your_key"
PUSHER_SECRET="your_secret"
PUSHER_CLUSTER="us2"

# Client-side Pusher config (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_PUSHER_KEY="your_key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# Whitelabel brand (optional — defaults = Perfect; see src/lib/brand.ts)
# NEXT_PUBLIC_BRAND_NAME="Perfect"
# NEXT_PUBLIC_BRAND_DISPLAY="Perfect"
# NEXT_PUBLIC_BRAND_TAGLINE="Team management, simplified."
# NEXT_PUBLIC_BRAND_EMAIL_DOMAIN="perfect.my"
# NEXT_PUBLIC_BRAND_LOGO_LIGHT="/logo.svg"
# NEXT_PUBLIC_BRAND_LOGO_DARK="/logo-white.svg"
# NEXT_PUBLIC_BRAND_COLOR="#0052cc"
