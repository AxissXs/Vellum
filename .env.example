# Database
# Use pooled connection for app runtime (Neon: -pooler suffix)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Use direct connection for migrations (Neon: no -pooler suffix)
DIRECT_DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Pusher (real-time updates) - https://pusher.com/channels
PUSHER_APP_ID="your_app_id"
PUSHER_KEY="your_key"
PUSHER_SECRET="your_secret"
PUSHER_CLUSTER="us2"

# Client-side Pusher config (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_PUSHER_KEY="your_key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"
